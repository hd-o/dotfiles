{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "git --no-pager diff *": "allow",
      "git diff *": "allow",
      "git status": "allow",
      "grep *": "allow",
      "npm run lint:changed": "allow",
      "npm run test -- *": "allow",
      "rg *": "allow",
      "tree *": "allow",
    },
    "edit": "ask",
    "webfetch": "allow",
    "websearch": "allow",
  },
  "mcp": {
    "context7": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
    },
    "linear": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/sse"
      ],
    },
    "playwright": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--isolated",
        "--browser=chromium"
      ],
    },
    "task-master-ai": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "--package=task-master-ai",
        "task-master-ai"
      ],
    },
  },
}
